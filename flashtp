-- ── Helper: slider ──
local function makeSlider(labelTxt, min, max, default, order, onChange)
    local container = ci("Frame", {
        Size=UDim2.new(1,0,0,38), BackgroundTransparency=1, LayoutOrder=order,
    }, contentFrame)

    ci("TextLabel", {
        Size=UDim2.new(0.55,0,0,16), Position=UDim2.new(0,4,0,0),
        BackgroundTransparency=1, Text=labelTxt,
        Font=Enum.Font.GothamMedium, TextColor3=C.Text, TextSize=11,
        TextXAlignment=Enum.TextXAlignment.Left,
    }, container)

    local valLbl = ci("TextLabel", {
        Size=UDim2.new(0.4,0,0,16), Position=UDim2.new(0.6,0,0,0),
        BackgroundColor3=Color3.fromRGB(28,30,70), BackgroundTransparency=0.3,
        Text=tostring(default), Font=Enum.Font.GothamBold,
        TextColor3=C.AccentBright, TextSize=11, TextXAlignment=Enum.TextXAlignment.Center,
        BorderSizePixel=0,
    }, container)
    corner(valLbl, 4)

    local track = ci("Frame", {
        Size=UDim2.new(1,-8,0,8), Position=UDim2.new(0,4,0,22),
        BackgroundColor3=C.SliderTrack, BorderSizePixel=0,
    }, container)
    corner(track, 4)

    local pct = (default-min)/(max-min)
    local fill = ci("Frame", {Size=UDim2.new(pct,0,1,0), BackgroundColor3=C.SliderFill, BorderSizePixel=0}, track)
    corner(fill, 4)

    local kn = ci("Frame", {
        Size=UDim2.new(0,14,0,14), Position=UDim2.new(pct,-7,0.5,-7),
        BackgroundColor3=Color3.fromRGB(255,255,255), BorderSizePixel=0, ZIndex=3,
    }, track)
    corner(kn, 7)
    stroke(kn, C.AccentBright, 1.5)

    local cur = default
    local dragging = false

    local function setValue(v)
        cur = math.clamp(v, min, max)
        local r = (cur-min)/(max-min)
        valLbl.Text = tostring(cur)
        fill.Size = UDim2.new(r,0,1,0)
        kn.Position = UDim2.new(r,-7,0.5,-7)
        onChange(cur)
    end

    local dragBtn = ci("TextButton", {
        Size=UDim2.new(1,10,1,10), Position=UDim2.new(0,-5,0,-5),
        BackgroundTransparency=1, Text="", ZIndex=5,
    }, track)
    dragBtn.MouseButton1Down:Connect(function() dragging=true end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if not dragging then return end
        if i.UserInputType==Enum.UserInputType.MouseMovement then
            local r = math.clamp((i.Position.X-track.AbsolutePosition.X)/track.AbsoluteSize.X, 0, 1)
            setValue(math.floor(min+(max-min)*r))
        end
    end)

    setValue(cur)
    return { Set=setValue, Get=function() return cur end }
end

