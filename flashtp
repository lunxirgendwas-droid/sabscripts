local function makeToggle(labelTxt, order, initOn, onChange)
    local row = ci("Frame", {
        Size=UDim2.new(1,0,0,30), BackgroundColor3=C.SectionBG,
        BackgroundTransparency=0.3, BorderSizePixel=0, LayoutOrder=order,
    }, contentFrame)
    corner(row, 6)

    ci("TextLabel", {
        Size=UDim2.new(1,-52,1,0), Position=UDim2.new(0,8,0,0),
        BackgroundTransparency=1, Text=labelTxt,
        Font=Enum.Font.GothamMedium, TextColor3=C.Text, TextSize=12,
        TextXAlignment=Enum.TextXAlignment.Left,
    }, row)

    local sw = ci("Frame", {
        Name="Switch", Size=UDim2.new(0,36,0,18), Position=UDim2.new(1,-44,0.5,-9),
        BackgroundColor3=initOn and C.ToggleOn or C.ToggleOff, BorderSizePixel=0,
    }, row)
    corner(sw, 9)
    stroke(sw, Color3.fromRGB(50,40,110), 1)

    local knob = ci("Frame", {
        Size=UDim2.new(0,14,0,14),
        Position=initOn and UDim2.new(1,-16,0.5,-7) or UDim2.new(0,2,0.5,-7),
        BackgroundColor3=initOn and C.KnobOn or C.KnobOff, BorderSizePixel=0,
    }, sw)
    corner(knob, 7)

    local on = initOn
    local btn = ci("TextButton", {Size=UDim2.new(1,0,1,0), BackgroundTransparency=1, Text="", ZIndex=5}, sw)
    btn.MouseButton1Click:Connect(function()
        on = not on
        tw(sw, {BackgroundColor3=on and C.ToggleOn or C.ToggleOff}, 0.12)
        tw(knob, {
            Position=on and UDim2.new(1,-16,0.5,-7) or UDim2.new(0,2,0.5,-7),
            BackgroundColor3=on and C.KnobOn or C.KnobOff,
        }, 0.12)
        onChange(on)
    end)
    return row
end

