local function ci(class, props, parent)
    local inst = Instance.new(class)
    for k, v in pairs(props) do inst[k] = v end
    if parent then inst.Parent = parent end
    return inst
end
local function corner(p, r) Instance.new("UICorner", p).CornerRadius = UDim.new(0, r or 8) end
local function stroke(p, col, th)
    local s = Instance.new("UIStroke", p)
    s.Color = col or C.Border; s.Thickness = th or 1; s.Transparency = 0.5
    return s
end
local function tw(obj, props, dur)
    TweenService:Create(obj, TweenInfo.new(dur or 0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props):Play()
end

