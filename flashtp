-- LOGIQUE GAME STRETCHER (extrait du hub)
-- =============================================
local gsEnabled   = false
local gsConn      = nil
local gsResConn   = nil

local function enableGameStretcher()
    gsEnabled = true
    if gsConn then gsConn:Disconnect() end
    gsConn = RunService.RenderStepped:Connect(function()
        if not gsEnabled then return end
        local cam = workspace.CurrentCamera
        if cam then cam.FieldOfView = 100 end
    end)
    if gsResConn then gsResConn:Disconnect() end
    gsResConn = RunService.RenderStepped:Connect(function()
        Camera.CFrame = Camera.CFrame * CFrame.new(0,0,0, 1,0,0, 0,0.7,0, 0,0,1)
    end)
end

local function disableGameStretcher()
    gsEnabled = false
    if gsConn    then gsConn:Disconnect();    gsConn    = nil end
    if gsResConn then gsResConn:Disconnect(); gsResConn = nil end
    local cam = workspace.CurrentCamera
    if cam then cam.FieldOfView = 70 end
end

